# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/deadlineai?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o

# ── Firebase Admin SDK ─────────────────────────────────────────────────────────
# Base64-encode your serviceAccount.json:
# node -e "console.log(Buffer.from(require('fs').readFileSync('serviceAccount.json')).toString('base64'))"
FIREBASE_SERVICE_ACCOUNT_KEY=paste_base64_encoded_json_here

# ── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Web Push VAPID ─────────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:you@yourdomain.com

# ── Client URL ─────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173